Context("ArbitraryString");


my @ions = (
    { symbol => 'H',  charge => '+',  protons => 1,  electrons => 0  }, 
    { symbol => 'Li', charge => '+',  protons => 3,  electrons => 2  },
    { symbol => 'Be', charge => '2+', protons => 4,  electrons => 2  },
    { symbol => 'B',  charge => '3+', protons => 5,  electrons => 2  },
    { symbol => 'N',  charge => '3-', protons => 7,  electrons => 10 },
    { symbol => 'O',  charge => '2-', protons => 8,  electrons => 10 },
    { symbol => 'F',  charge => '-',  protons => 9,  electrons => 10 },
    { symbol => 'Na', charge => '+',  protons => 11, electrons => 10 },
    { symbol => 'Mg', charge => '2+', protons => 12, electrons => 10 },
    { symbol => 'Al', charge => '3+', protons => 13, electrons => 10 },
    { symbol => 'P',  charge => '3-', protons => 15, electrons => 18 },
    { symbol => 'S',  charge => '2-', protons => 16, electrons => 18 },
    { symbol => 'Cl', charge => '-',  protons => 17, electrons => 18 },
    { symbol => 'K',  charge => '+',  protons => 19, electrons => 18 },
    { symbol => 'Ca', charge => '2+', protons => 20, electrons => 18 },
);

@elements = random_subset(4, @ions);

$ans_rule1 = ans_rule(4);
$ans_rule2 = ans_rule(4);
$ans_rule3 = ans_rule(4);
$ans_rule4 = ans_rule(4);

ANS(String($elements[0]{charge})->cmp(
    checker => sub {
        my ($correct, $student, $ans) = @_;

        # Remove all whitespace.
        $student =~ s/~~s+//g;

        if ($student =~ /^(?:[+-]1|1[+-])$/) {
            $ans->{ans_message} =
            "Do not include the number 1. Enter 1+ as + and 1- as -.";
        }
        elsif ($student =~ /^[+-]~~d+$/) {
            $ans->{ans_message} =
            "Enter the charge with the number before the sign. "
          . "2+ or 3- are examples of the correct format.";
        }
        return $correct eq $student;
    }
));
ANS(String($elements[1]{charge})->cmp(
    checker => sub {
        my ($correct, $student, $ans) = @_;

